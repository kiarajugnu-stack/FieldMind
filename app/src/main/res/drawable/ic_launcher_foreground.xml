<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- FieldMind mark: a leaf observed through a research lens, drawn in the brand
         forest-green / ochre palette. Content sits within the adaptive-icon safe zone. -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.92"
        android:scaleY="0.92">

        <!-- Magnifier handle -->
        <path
            android:pathData="M70.5,70.5 L82,82"
            android:strokeColor="#8A5A00"
            android:strokeWidth="9"
            android:strokeLineCap="round" />
        <path
            android:pathData="M70.5,70.5 L82,82"
            android:strokeColor="#C77800"
            android:strokeWidth="4"
            android:strokeLineCap="round" />

        <!-- Lens ring -->
        <path
            android:pathData="M48,20 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0"
            android:fillColor="#00000000"
            android:strokeColor="#1F6B4C"
            android:strokeWidth="9" />

        <!-- Lens glass -->
        <path
            android:pathData="M48,20 m-25,0 a25,25 0 1,0 50,0 a25,25 0 1,0 -50,0">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="23"
                    android:startY="-5"
                    android:endX="73"
                    android:endY="45"
                    android:startColor="#EAF7EE"
                    android:endColor="#A8F2C8" />
            </aapt:attr>
        </path>

        <!-- Leaf body -->
        <path
            android:pathData="M48,4 C64,12 66,32 48,40 C30,32 32,12 48,4 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="36"
                    android:startY="6"
                    android:endX="60"
                    android:endY="40"
                    android:startColor="#2E8B57"
                    android:endColor="#0F4D32" />
            </aapt:attr>
        </path>

        <!-- Leaf vein -->
        <path
            android:pathData="M48,8 L48,38"
            android:strokeColor="#EAF7EE"
            android:strokeWidth="2.4"
            android:strokeLineCap="round"
            android:strokeAlpha="0.85" />
        <path
            android:pathData="M48,17 L40,13 M48,23 L56,19 M48,29 L41,26"
            android:strokeColor="#EAF7EE"
            android:strokeWidth="1.8"
            android:strokeLineCap="round"
            android:strokeAlpha="0.7" />
    </group>
</vector>
