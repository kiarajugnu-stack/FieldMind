<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        FieldMind adaptive icon — foreground layer.
        A field-research emblem: leaf specimen under a precision lens,
        encircled by data points and compass marks.
        Brand palette: forest green (#1F6B4C, #2E8B57), ochre (#C77800).
    -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.88"
        android:scaleY="0.88"
        android:translationX="6"
        android:translationY="6">

        <!-- ── Outer lens ring (precision instrument) ──────────── -->
        <path
            android:pathData="M48,20 m-33,0 a33,33 0 1,0 66,0 a33,33 0 1,0 -66,0"
            android:fillColor="#00000000"
            android:strokeColor="#1F6B4C"
            android:strokeWidth="7.5" />
        <!-- Inner ring highlight -->
        <path
            android:pathData="M48,20 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0"
            android:fillColor="#00000000"
            android:strokeColor="#2E8B57"
            android:strokeWidth="1.5"
            android:strokeAlpha="0.5" />

        <!-- ── Compass / measurement marks on the lens rim ─────── -->
        <!-- Top mark -->
        <path android:pathData="M48,4 L48,7" android:strokeColor="#8A5A00" android:strokeWidth="2" android:strokeLineCap="round" android:strokeAlpha="0.8" />
        <!-- Right mark -->
        <path android:pathData="M78,20 L75,20" android:strokeColor="#8A5A00" android:strokeWidth="2" android:strokeLineCap="round" android:strokeAlpha="0.8" />
        <!-- Bottom mark -->
        <path android:pathData="M48,40 L48,37" android:strokeColor="#8A5A00" android:strokeWidth="2" android:strokeLineCap="round" android:strokeAlpha="0.8" />
        <!-- Left mark -->
        <path android:pathData="M18,20 L21,20" android:strokeColor="#8A5A00" android:strokeWidth="2" android:strokeLineCap="round" android:strokeAlpha="0.8" />
        <!-- NE tick -->
        <path android:pathData="M69,11 L67,13" android:strokeColor="#8A5A00" android:strokeWidth="1.6" android:strokeLineCap="round" android:strokeAlpha="0.5" />
        <!-- SE tick -->
        <path android:pathData="M69,29 L67,27" android:strokeColor="#8A5A00" android:strokeWidth="1.6" android:strokeLineCap="round" android:strokeAlpha="0.5" />
        <!-- SW tick -->
        <path android:pathData="M27,29 L29,27" android:strokeColor="#8A5A00" android:strokeWidth="1.6" android:strokeLineCap="round" android:strokeAlpha="0.5" />
        <!-- NW tick -->
        <path android:pathData="M27,11 L29,13" android:strokeColor="#8A5A00" android:strokeWidth="1.6" android:strokeLineCap="round" android:strokeAlpha="0.5" />

        <!-- ── Lens glass gradient ─────────────────────────────── -->
        <path
            android:pathData="M48,20 m-27,0 a27,27 0 1,0 54,0 a27,27 0 1,0 -54,0">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="21"
                    android:startY="-3"
                    android:endX="75"
                    android:endY="47"
                    android:startColor="#EAF7EE"
                    android:endColor="#A8F2C8" />
            </aapt:attr>
        </path>

        <!-- ── Glass reflection highlight arc ──────────────────── -->
        <path
            android:pathData="M32,6 Q42,1 55,3"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="2.5"
            android:strokeLineCap="round"
            android:strokeAlpha="0.7" />
        <path
            android:pathData="M31,10 Q36,7 44,7"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:strokeAlpha="0.4" />

        <!-- ── Leaf body (main specimen) ───────────────────────── -->
        <!-- Shadow under leaf -->
        <path
            android:pathData="M48,6 C62,14 64,33 48,40 C34,33 36,14 48,6 Z"
            android:fillColor="#0F3D2A"
            android:strokeAlpha="0.25"
            android:translateX="1"
            android:translateY="1.5" />
        <!-- Main leaf -->
        <path
            android:pathData="M48,4 C64,12 66,32 48,40 C30,32 32,12 48,4 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="34"
                    android:startY="6"
                    android:endX="62"
                    android:endY="38"
                    android:startColor="#3CB371"
                    android:endColor="#1A6B3C" />
            </aapt:attr>
        </path>

        <!-- ── Leaf central vein ───────────────────────────────── -->
        <path
            android:pathData="M48,8 Q46,22 48,38"
            android:strokeColor="#D4EDDA"
            android:strokeWidth="2.2"
            android:strokeLineCap="round"
            android:strokeAlpha="0.9" />

        <!-- ── Leaf secondary veins (angled) ──────────────────── -->
        <!-- Upper left veins -->
        <path android:pathData="M47.5,13 Q42,11 38,14" android:strokeColor="#D4EDDA" android:strokeWidth="1.5" android:strokeLineCap="round" android:strokeAlpha="0.65" />
        <path android:pathData="M47.5,18 Q39,16 34,20" android:strokeColor="#D4EDDA" android:strokeWidth="1.5" android:strokeLineCap="round" android:strokeAlpha="0.65" />
        <path android:pathData="M47.5,23 Q41,21 36,25" android:strokeColor="#D4EDDA" android:strokeWidth="1.5" android:strokeLineCap="round" android:strokeAlpha="0.65" />
        <path android:pathData="M47.5,28 Q43,26 38,30" android:strokeColor="#D4EDDA" android:strokeWidth="1.4" android:strokeLineCap="round" android:strokeAlpha="0.55" />
        <!-- Upper right veins -->
        <path android:pathData="M48.5,13 Q54,11 58,14" android:strokeColor="#D4EDDA" android:strokeWidth="1.5" android:strokeLineCap="round" android:strokeAlpha="0.65" />
        <path android:pathData="M48.5,18 Q57,16 62,20" android:strokeColor="#D4EDDA" android:strokeWidth="1.5" android:strokeLineCap="round" android:strokeAlpha="0.65" />
        <path android:pathData="M48.5,23 Q55,21 60,25" android:strokeColor="#D4EDDA" android:strokeWidth="1.5" android:strokeLineCap="round" android:strokeAlpha="0.65" />
        <path android:pathData="M48.5,28 Q53,26 58,30" android:strokeColor="#D4EDDA" android:strokeWidth="1.4" android:strokeLineCap="round" android:strokeAlpha="0.55" />

        <!-- ── Magnifier handle ────────────────────────────────── -->
        <!-- Handle shadow -->
        <path
            android:pathData="M71.5,71.5 L83,83"
            android:strokeColor="#0F3D2A"
            android:strokeWidth="8.5"
            android:strokeLineCap="round"
            android:strokeAlpha="0.2"
            android:translateX="1"
            android:translateY="1" />
        <!-- Handle outer -->
        <path
            android:pathData="M71.5,71.5 L83,83"
            android:strokeColor="#8A5A00"
            android:strokeWidth="8"
            android:strokeLineCap="round" />
        <!-- Handle inner highlight -->
        <path
            android:pathData="M71.5,71.5 L83,83"
            android:strokeColor="#C77800"
            android:strokeWidth="3.5"
            android:strokeLineCap="round" />
        <!-- Handle grip lines -->
        <path android:pathData="M74,74 L74.5,74.5" android:strokeColor="#5C3A00" android:strokeWidth="1.8" android:strokeLineCap="round" android:strokeAlpha="0.5" />
        <path android:pathData="M77,77 L77.5,77.5" android:strokeColor="#5C3A00" android:strokeWidth="1.8" android:strokeLineCap="round" android:strokeAlpha="0.5" />
        <path android:pathData="M80,80 L80.5,80.5" android:strokeColor="#5C3A00" android:strokeWidth="1.8" android:strokeLineCap="round" android:strokeAlpha="0.5" />

        <!-- ── Data / observation dots around the lens ─────────── -->
        <!-- Top-left cluster -->
        <circle cx="20" cy="8" r="2.2" android:fillColor="#2E8B57" />
        <circle cx="15" cy="14" r="1.5" android:fillColor="#C77800" />
        <circle cx="25" cy="4" r="1.2" android:fillColor="#1565C0" />
        <!-- Top-right cluster -->
        <circle cx="74" cy="6" r="1.8" android:fillColor="#C77800" />
        <circle cx="80" cy="12" r="1.3" android:fillColor="#2E8B57" />
        <!-- Bottom area -->
        <circle cx="28" cy="38" r="1.6" android:fillColor="#1565C0" />
        <circle cx="22" cy="34" r="1.1" android:fillColor="#2E8B57" />
        <circle cx="76" cy="36" r="1.4" android:fillColor="#C77800" />

        <!-- ── Tiny star/plus markers (field-note annotations) ─── -->
        <!-- Cross mark 1 -->
        <path android:pathData="M78,7 L81,10 M81,7 L78,10" android:strokeColor="#1565C0" android:strokeWidth="1.2" android:strokeLineCap="round" android:strokeAlpha="0.6" />
        <!-- Cross mark 2 -->
        <path android:pathData="M18,38 L21,41 M21,38 L18,41" android:strokeColor="#C77800" android:strokeWidth="1.2" android:strokeLineCap="round" android:strokeAlpha="0.6" />

        <!-- ── Subtle data ring (orbit arc) ────────────────────── -->
        <path
            android:pathData="M16,20 A32,32 0 0,1 22,6"
            android:strokeColor="#C77800"
            android:strokeWidth="1"
            android:strokeAlpha="0.35"
            android:fillColor="#00000000"
            android:strokeDasharray="2,4" />
        <path
            android:pathData="M74,6 A32,32 0 0,1 80,20"
            android:strokeColor="#1565C0"
            android:strokeWidth="1"
            android:strokeAlpha="0.35"
            android:fillColor="#00000000"
            android:strokeDasharray="2,4" />

    </group>
</vector>
